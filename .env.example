# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_id_here
# Optional: Set this if your VPS/System needs a proxy to reach Telegram (e.g. NordVPN, V2Ray)
# HTTP_PROXY=http://127.0.0.1:10809

# 3X-UI VPN Panel Configuration
# The base URL to your 3X-UI admin panel (do not include trailing slash)
VPN_PANEL_URL=http://your-server-ip:2053
# The admin username for the panel
VPN_PANEL_USERNAME=admin
# The admin password for the panel
VPN_PANEL_PASSWORD=your_secure_password
# The integer ID of the inbound you want to create users under (check your panel for this ID)
VPN_INBOUND_ID=1
# The remarks/address to format the vless:// connection string with (e.g. your domain or IP)
VPN_SERVER_REMARKS=vpn.yourdomain.com

# Database Configurations
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=postgres
DB_PASS=postgres
DB_NAME=napster_vpn

# VPN API Configuration
VPN_API_URL=http://your-vpn-panel.com/api
VPN_API_USER=admin
VPN_API_PASS=password
